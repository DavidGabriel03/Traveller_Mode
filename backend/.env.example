# Baza de date MySQL (local sau cloud - ex. TiDB Cloud)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=traveller_mode
DB_USER=root
DB_PASS=schimba_aceasta_parola
DB_SSL=false

# Setează true dacă baza de date cloud cere SSL (ex. TiDB Cloud)
# DB_SSL=true

# Secret pentru JWT (folosește un string lung, random, în producție)
JWT_SECRET=schimba_acest_secret

# Cheia API pentru Gemini AI
GEMINI_API_KEY=

# URL-ul frontend-ului deployat (pentru CORS), ex: https://traveller-mode.vercel.app
FRONTEND_URL=http://localhost:5173

# URL-ul public al acestui backend (folosit la generarea link-urilor de upload)
BACKEND_URL=http://localhost:5000

# Portul pe care rulează serverul (Render/Railway îl setează automat)
PORT=5000
